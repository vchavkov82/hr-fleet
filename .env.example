# ══════════════════════════════════════════════════════════════════════════════
# HR Product — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Caddy / Domains ──────────────────────────────────────────────────────────
HR_DOMAIN=hr.localhost
HR_BLOG_DOMAIN=blog.hr.localhost
HR_DOCS_DOMAIN=docs.localhost
ACME_EMAIL=admin@hr.example.com

# ── CDN ──────────────────────────────────────────────────────────────────────
# Set to CDN domain for Next.js assetPrefix, e.g. https://cdn.hr.example.com
# Leave empty to serve assets from the same domain.
NEXT_PUBLIC_CDN_URL=
