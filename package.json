{
  "name": "@hr/workspace",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "packages/design-system",
    "www",
    "blog",
    "docs"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "cd www && PORT=3010 bun dev",
    "dev:www": "cd www && PORT=3010 bun dev",
    "dev:blog": "cd blog && bun dev",
    "dev:docs": "cd docs && bun dev",
    "build": "node_modules/.bin/turbo run build --cache-workers=4",
    "build:www": "node_modules/.bin/turbo run build --filter=@hr/www --cache-workers=4",
    "build:blog": "node_modules/.bin/turbo run build --filter=@hr/blog --cache-workers=4",
    "build:docs": "node_modules/.bin/turbo run build --filter=@hr/docs --cache-workers=4",
    "lint": "node_modules/.bin/turbo run lint",
    "typecheck": "node_modules/.bin/turbo run typecheck",
    "test": "cd www && bun run test",
    "test:watch": "cd www && bun run test:watch",
    "test:ui": "cd www && bun run test:ui",
    "test:e2e": "cd www && bun run test:e2e",
    "test:e2e:debug": "cd www && bun run test:e2e:debug",
    "test:e2e:ui": "cd www && bun run test:e2e:ui",
    "test:all": "cd www && bun run test",
    "clean": "rm -rf node_modules www/node_modules blog/node_modules docs/node_modules && echo 'node_modules cleaned'",
    "clean:cache": "rm -rf www/.next www/.next/cache www/node_modules/.cache .turbo && echo 'Build cache cleaned'",
    "prebuild": "bun run typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "turbo": "^2.8.12"
  },
  "lint-staged": {
    "www/**/*.{ts,tsx}": [
      "cd www && bun lint:fix",
      "cd www && bunx prettier --write"
    ],
    "www/**/*.{json,md}": [
      "cd www && bunx prettier --write"
    ],
    "blog/**/*.{ts,tsx,astro}": [
      "cd blog && bunx eslint --fix",
      "cd blog && bunx prettier --write"
    ],
    "blog/**/*.{json,md}": [
      "cd blog && bunx prettier --write"
    ],
    "docs/**/*.{ts,tsx,astro,mdx}": [
      "cd docs && bunx prettier --write"
    ]
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@an-sdk/agent": "^0.0.5",
    "zod": "^4.3.6"
  }
}
