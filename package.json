{
  "name": "@hr/workspace",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "prepare": "husky",
    "dev": "cd apps/web && PORT=5010 pnpm dev",
    "dev:www": "cd apps/web && PORT=5010 pnpm dev",
    "dev:blog": "cd apps/blog && pnpm dev",
    "dev:docs": "cd apps/docs && pnpm dev",
    "build": "turbo run build --filter=@hr/www --cache-workers=4 && turbo run build --filter=@hr/blog --cache-workers=4",
    "build:www": "node_modules/.bin/turbo run build --filter=@hr/www --cache-workers=4",
    "build:blog": "node_modules/.bin/turbo run build --filter=@hr/blog --cache-workers=4",
    "build:docs": "node_modules/.bin/turbo run build --filter=@hr/docs --cache-workers=4",
    "lint": "node_modules/.bin/turbo run lint",
    "typecheck": "node_modules/.bin/turbo run typecheck",
    "test": "turbo run test --cache-workers=4",
    "test:web": "pnpm --filter @hr/www run test",
    "test:watch": "cd apps/web && pnpm run test:watch",
    "test:ui": "cd apps/web && pnpm run test:ui",
    "test:e2e": "cd apps/web && pnpm run test:e2e",
    "test:e2e:chromium": "cd apps/web && pnpm run test:e2e:chromium",
    "test:e2e:debug": "cd apps/web && pnpm run test:e2e:debug",
    "test:e2e:ui": "cd apps/web && pnpm run test:e2e:ui",
    "test:all": "turbo run test --cache-workers=4",
    "clean": "rm -rf node_modules apps/web/node_modules apps/blog/node_modules apps/docs/node_modules && echo 'node_modules cleaned'",
    "clean:cache": "rm -rf apps/web/.next apps/web/.next/cache apps/web/node_modules/.cache .turbo && echo 'Build cache cleaned'",
    "check": "turbo run typecheck lint --cache-workers=4"
  },
  "devDependencies": {
    "@parcel/watcher-linux-x64-glibc": "^2.5.6",
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "turbo": "^2.8.20"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "cd apps/web && pnpm lint:fix",
      "cd apps/web && pnpm dlx prettier --write"
    ],
    "apps/web/**/*.{json,md}": [
      "cd apps/web && pnpm dlx prettier --write"
    ],
    "apps/blog/**/*.{ts,tsx,astro}": [
      "cd apps/blog && pnpm dlx eslint --fix",
      "cd apps/blog && pnpm dlx prettier --write"
    ],
    "apps/blog/**/*.{json,md}": [
      "cd apps/blog && pnpm dlx prettier --write"
    ],
    "apps/docs/**/*.{ts,tsx,astro,mdx}": [
      "cd apps/docs && pnpm dlx prettier --write"
    ]
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@an-sdk/nextjs>ai": "$ai",
    "@an-sdk/nextjs>@ai-sdk/react": "$@ai-sdk/react",
    "@an-sdk/nextjs>@an-sdk/react": "$@an-sdk/react",
    "@an-sdk/react>ai": "$ai",
    "@an-sdk/react>@ai-sdk/react": "$@ai-sdk/react"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@an-sdk/agent": "^0.0.5",
    "@parcel/watcher": "^2.5.6",
    "zod": "^4.3.6"
  }
}
