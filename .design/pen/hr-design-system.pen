    {
      "id": "typography",
      "name": "Typography",
      "frames": [
        {
          "id": "typography-frame",
          "name": "Typography Scale",
          "type": "frame",
          "x": 0,
          "y": 0,
          "width": 1440,
          "height": 2200,
          "fill": "{color/background}",
          "children": [
            {
              "type": "text",
              "x": 60,
