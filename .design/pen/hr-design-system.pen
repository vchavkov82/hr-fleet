                { "type": "rectangle", "x": 560, "y": 0, "width": 120, "height": 80, "fill": "{color/primary/600}", "label": "600\n#133AAB" },
                { "type": "rectangle", "x": 700, "y": 0, "width": 120, "height": 80, "fill": "{color/primary/700}", "label": "700\n#0E2E80" },
                { "type": "rectangle", "x": 840, "y": 0, "width": 120, "height": 80, "fill": "{color/primary/900}", "label": "900\n#0A1F5C" }
