                { "type": "text", "x": 0, "y": 280, "content": "Black (900) — The quick brown fox", "fontSize": "1.125rem", "fontWeight": "{typography/fontWeight/black}", "fontFamily": "{typography/fontFamily/sans}", "fill": "{color/foreground}" }
