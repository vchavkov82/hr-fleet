{
  "version": "1.0",
  "name": "HR Design System",
  "description": "Source of truth for the HR SaaS platform design system",
  "created": "2026-03-15",
  "variables": {
    "collections": {
      "Light Theme": {
        "color/primary/default": "#1B4DDB",
        "color/primary/light": "#3B6EF0",
        "color/primary/dark": "#133AAB",
        "color/primary/50": "#EEF2FF",
        "color/primary/100": "#DBE4FE",
        "color/primary/200": "#BCC8FC",
        "color/primary/500": "#1B4DDB",
        "color/primary/600": "#133AAB",
        "color/primary/700": "#0E2E80",
        "color/primary/900": "#0A1F5C",
        "color/accent/default": "#0EA5E9",
        "color/accent/light": "#38BDF8",
        "color/accent/dark": "#0284C7",
        "color/navy/default": "#0F172A",
        "color/navy/light": "#1E293B",
        "color/navy/dark": "#020617",
