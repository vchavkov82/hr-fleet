                { "type": "rectangle", "x": 280, "y": 0, "width": 120, "height": 80, "fill": "{color/navy/dark}", "label": "Dark\n#020617" },
                { "type": "rectangle", "x": 420, "y": 0, "width": 120, "height": 80, "fill": "{color/navy/deep}", "label": "Deep\n#030B24" }
              ]
