              "fontSize": "2.25rem",
              "fontWeight": "700",
              "fill": "{color/foreground}"
            },
            {
              "type": "text",
              "x": 60,
              "y": 120,
              "content": "Font Families",
              "fontFamily": "{typography/fontFamily/heading}",
              "fontSize": "1.25rem",
              "fontWeight": "600",
              "fill": "{color/foreground}"
            },
            {
              "type": "text",
              "x": 60,
              "y": 160,
              "content": "Inter (Body) — The quick brown fox jumps over the lazy dog",
