                { "type": "text", "x": 0, "y": 80, "content": "Normal (400) — The quick brown fox", "fontSize": "1.125rem", "fontWeight": "{typography/fontWeight/normal}", "fontFamily": "{typography/fontFamily/sans}", "fill": "{color/foreground}" },
