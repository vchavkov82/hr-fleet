                { "type": "text", "x": 0, "y": 200, "content": "Bold (700) — The quick brown fox", "fontSize": "1.125rem", "fontWeight": "{typography/fontWeight/bold}", "fontFamily": "{typography/fontFamily/sans}", "fill": "{color/foreground}" },
