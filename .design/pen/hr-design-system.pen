                { "type": "text", "x": 0, "y": 150, "content": "xl (1.25rem) — The quick brown fox", "fontSize": "{typography/fontSize/xl}", "fontFamily": "{typography/fontFamily/sans}", "fill": "{color/foreground}" },
                { "type": "text", "x": 0, "y": 200, "content": "2xl (1.5rem) — The quick brown fox", "fontSize": "{typography/fontSize/2xl}", "fontFamily": "{typography/fontFamily/sans}", "fill": "{color/foreground}" },
                { "type": "text", "x": 0, "y": 260, "content": "3xl (1.875rem) — The quick brown fox", "fontSize": "{typography/fontSize/3xl}", "fontFamily": "{typography/fontFamily/sans}", "fill": "{color/foreground}" },
