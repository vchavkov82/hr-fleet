        "color/gray/700": "#374151",
        "color/gray/800": "#1F2937",
        "color/gray/900": "#111827"
      },
      "Dark Theme": {
        "color/primary/default": "#3B6EF0",
        "color/primary/light": "#5B8AF5",
        "color/primary/dark": "#1B4DDB",
        "color/accent/default": "#38BDF8",
        "color/accent/light": "#7DD3FC",
        "color/accent/dark": "#0EA5E9",
        "color/success": "#34D399",
        "color/warning": "#FBBF24",
        "color/error": "#F87171",
        "color/info": "#38BDF8",
        "color/surface/default": "#0F172A",
        "color/surface/light": "#1E293B",
        "color/surface/lighter": "#334155",
        "color/background": "#020617",
        "color/foreground": "#F1F5F9",
        "color/muted": "#94A3B8",
        "color/border": "#334155",
        "color/gray/50": "#111827",
        "color/gray/100": "#1F2937",
        "color/gray/200": "#374151",
        "color/gray/300": "#4B5563",
        "color/gray/400": "#6B7280",
        "color/gray/500": "#9CA3AF",
        "color/gray/600": "#D1D5DB",
        "color/gray/700": "#E5E7EB",
        "color/gray/800": "#F3F4F6",
        "color/gray/900": "#F9FAFB"
      },
      "Global": {
        "typography/fontFamily/sans": "var(--font-inter), system-ui, sans-serif",
        "typography/fontFamily/heading": "var(--font-mulish), var(--font-inter), system-ui, sans-serif",
        "typography/fontSize/xs": "0.75rem",
        "typography/fontSize/sm": "0.875rem",
        "typography/fontSize/base": "1rem",
        "typography/fontSize/lg": "1.125rem",
        "typography/fontSize/xl": "1.25rem",
        "typography/fontSize/2xl": "1.5rem",
        "typography/fontSize/3xl": "1.875rem",
        "typography/fontSize/4xl": "2.25rem",
        "typography/fontSize/5xl": "3rem",
        "typography/lineHeight/xs": "1rem",
        "typography/lineHeight/sm": "1.25rem",
        "typography/lineHeight/base": "1.5rem",
        "typography/lineHeight/lg": "1.75rem",
        "typography/lineHeight/xl": "1.75rem",
        "typography/lineHeight/2xl": "2rem",
        "typography/lineHeight/3xl": "2.25rem",
        "typography/lineHeight/4xl": "2.5rem",
        "typography/lineHeight/5xl": "1",
        "typography/fontWeight/extralight": "200",
        "typography/fontWeight/light": "300",
        "typography/fontWeight/normal": "400",
        "typography/fontWeight/medium": "500",
        "typography/fontWeight/semibold": "600",
        "typography/fontWeight/bold": "700",
        "typography/fontWeight/extrabold": "800",
        "typography/fontWeight/black": "900",
        "spacing/0": "0",
        "spacing/1": "0.25rem",
        "spacing/2": "0.5rem",
        "spacing/3": "0.75rem",
        "spacing/4": "1rem",
        "spacing/5": "1.25rem",
        "spacing/6": "1.5rem",
        "spacing/8": "2rem",
        "spacing/10": "2.5rem",
        "spacing/12": "3rem",
        "spacing/16": "4rem",
        "spacing/20": "5rem",
        "spacing/24": "6rem",
        "spacing/32": "8rem",
        "spacing/40": "10rem",
        "spacing/48": "12rem",
        "spacing/64": "16rem",
        "shadow/sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "shadow/default": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
        "shadow/md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
        "shadow/lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
        "shadow/xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
        "shadow/none": "none",
        "borderRadius/none": "0",
        "borderRadius/sm": "0.125rem",
        "borderRadius/default": "0.25rem",
        "borderRadius/md": "0.375rem",
        "borderRadius/lg": "0.5rem",
        "borderRadius/xl": "0.75rem",
        "borderRadius/2xl": "1rem",
        "borderRadius/full": "9999px",
        "zIndex/0": "0",
        "zIndex/10": "10",
        "zIndex/20": "20",
        "zIndex/30": "30",
        "zIndex/40": "40",
        "zIndex/50": "50",
        "zIndex/dropdown": "1000",
        "zIndex/sticky": "1020",
        "zIndex/fixed": "1030",
        "zIndex/modal-backdrop": "1040",
        "zIndex/modal": "1050",
        "zIndex/popover": "1060",
        "zIndex/tooltip": "1070",
        "zIndex/toast": "1080",
        "component/button/paddingX": "{spacing/4}",
        "component/button/paddingY": "{spacing/2}",
        "component/button/borderRadius": "{borderRadius/lg}",
        "component/button/fontSize": "{typography/fontSize/sm}",
        "component/button/fontWeight": "{typography/fontWeight/medium}",
        "component/input/paddingX": "{spacing/3}",
        "component/input/paddingY": "{spacing/2}",
        "component/input/borderRadius": "{borderRadius/md}",
        "component/input/fontSize": "{typography/fontSize/sm}",
        "component/input/borderColor": "{color/border}",
        "component/card/padding": "{spacing/6}",
        "component/card/borderRadius": "{borderRadius/xl}",
        "component/card/shadow": "{shadow/md}",
        "component/card/background": "{color/surface/default}",
        "component/modal/borderRadius": "{borderRadius/2xl}",
        "component/modal/shadow": "{shadow/xl}",
        "component/modal/backdropColor": "rgba(0, 0, 0, 0.5)"
      }
    }
  },
  "pages": [
    {
      "id": "cover",
      "name": "Cover",
      "frames": [
        {
          "id": "cover-frame",
          "name": "Cover",
          "type": "frame",
          "x": 0,
          "y": 0,
          "width": 1440,
          "height": 900,
          "fill": "{color/background}",
          "children": [
            {
              "type": "text",
              "x": 120,
              "y": 300,
              "content": "HR Design System",
              "fontFamily": "{typography/fontFamily/heading}",
              "fontSize": "3rem",
              "fontWeight": "700",
              "fill": "{color/foreground}"
            },
            {
              "type": "text",
              "x": 120,
              "y": 380,
              "content": "Source of truth for the HR SaaS platform design system",
              "fontFamily": "{typography/fontFamily/sans}",
              "fontSize": "1.25rem",
              "fontWeight": "400",
              "fill": "{color/muted}"
            },
            {
              "type": "text",
              "x": 120,
              "y": 440,
              "content": "Version 1.0 | 2026-03-15",
              "fontFamily": "{typography/fontFamily/sans}",
              "fontSize": "1rem",
              "fontWeight": "400",
              "fill": "{color/muted}"
            }
          ]
        }
      ]
    },
    {
      "id": "colors",
      "name": "Colors",
