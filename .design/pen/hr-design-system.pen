                { "type": "rectangle", "x": 840, "y": 0, "width": 120, "height": 80, "fill": "{color/gray/600}", "label": "600\n#4B5563" },
                { "type": "rectangle", "x": 980, "y": 0, "width": 120, "height": 80, "fill": "{color/gray/700}", "label": "700\n#374151" },
                { "type": "rectangle", "x": 1120, "y": 0, "width": 120, "height": 80, "fill": "{color/gray/800}", "label": "800\n#1F2937" },
