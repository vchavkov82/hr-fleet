---
/**
 * Custom Header matching Figma/marketing design system.
 * DESIGN_ALIGNMENT.md: Header — sticky, nav links, language switcher, CTA. Height ~64px.
 */
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const locale = Astro.locals.starlightRoute.locale ?? 'en';
const baseUrl = 'https://jobshr.com';
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Features', href: '/features' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
  { label: 'Help Center', href: '/help-center' },
  { label: 'Contact', href: '/contact' },
];
---

<div class="header-bar">
  <div class="header-inner">
    <a href={baseUrl + (locale === 'root' ? '' : `/${locale}`)} class="logo-link">
      <div class="logo-icon">
        <svg class="logo-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
        </svg>
      </div>
      <span class="logo-text">HR Service</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={`${baseUrl}/${locale === 'root' ? 'en' : locale}${link.href}`} class="nav-link">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-right">
      {shouldRenderSearch && (
        <div class="search-wrap">
          <Search />
        </div>
      )}
      <div class="header-controls">
        <ThemeSelect />
        <LanguageSelect />
        <a href={`${baseUrl}/${locale === 'root' ? 'en' : locale}/auth/login`} class="login-link">Sign In</a>
        <a href={`${baseUrl}/${locale === 'root' ? 'en' : locale}/auth/sign-up`} class="cta-button">Get Started</a>
      </div>
    </div>
  </div>
</div>

<style>
  .header-bar {
    background-color: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    height: 64px;
    display: flex;
    align-items: center;
  }

  .header-inner {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .header-inner { padding: 0 1.5rem; }
  }

  @media (min-width: 1024px) {
    .header-inner { padding: 0 2rem; }
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    width: 2.5rem;
    height: 2.5rem;
    background: #1B4DDB;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-svg {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    font-size: 0.875rem;
    color: #4b5563;
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-link:hover {
    color: #0F172A;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 1;
    justify-content: flex-end;
    min-width: 0;
  }

  .search-wrap {
    flex: 1;
    max-width: 16rem;
    min-width: 0;
  }

  @media (min-width: 50rem) {
    .search-wrap { max-width: 24rem; }
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .login-link {
    font-size: 0.875rem;
    color: #4b5563;
    text-decoration: none;
    transition: color 0.15s;
  }

  .login-link:hover {
    color: #0F172A;
  }

  .cta-button {
    padding: 0.5rem 1rem;
    background: #1B4DDB;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s;
  }

  .cta-button:hover {
    background: #133AAB;
  }

</style>
