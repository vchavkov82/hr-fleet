---
/**
 * Custom Footer matching Figma/marketing design system.
 * DESIGN_ALIGNMENT.md: Footer — links, legal, social. bg-navy-dark.
 */
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import config from 'virtual:starlight/user-config';

const locale = Astro.locals.starlightRoute.locale ?? 'en';
const baseUrl = 'https://jobshr.com';
const blogUrl = 'https://hr.svc.chavkov.com';
const localePath = locale === 'root' ? 'en' : locale;

const columns = [
  {
    label: 'Product',
    links: [
      { label: 'Features', href: `${baseUrl}/${localePath}/features` },
      { label: 'Pricing', href: `${baseUrl}/${localePath}/pricing` },
      { label: 'HR Tools', href: `${baseUrl}/${localePath}/hr-tools` },
    ],
  },
  {
    label: 'Company',
    links: [
      { label: 'About', href: `${baseUrl}/${localePath}/about` },
      { label: 'Blog', href: `${blogUrl}/` },
      { label: 'Docs', href: '/' },
      { label: 'Help Center', href: `${baseUrl}/${localePath}/help-center` },
      { label: 'Contact', href: `${baseUrl}/${localePath}/contact` },
      { label: 'Careers', href: `${baseUrl}/${localePath}/careers` },
    ],
  },
  {
    label: 'Legal',
    links: [
      { label: 'Terms of Service', href: `${baseUrl}/${localePath}/terms` },
      { label: 'Privacy Policy', href: `${baseUrl}/${localePath}/privacy` },
      { label: 'Cookie Policy', href: `${baseUrl}/${localePath}/cookies` },
    ],
  },
];
---

<div class="doc-footer">
  <div class="meta sl-flex">
    <EditLink />
    <LastUpdated />
  </div>
  <Pagination />
  {config.credits && (
    <a class="kudos sl-flex" href="https://starlight.astro.build">
      Built with Starlight
    </a>
  )}
</div>

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="footer-brand">
      <a href={baseUrl + (locale === 'root' ? '' : `/${localePath}`)} class="footer-logo-link">
        <div class="footer-logo-icon">
          <svg class="footer-logo-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
          </svg>
        </div>
        <span class="footer-logo-text">HR Service</span>
      </a>
      <p class="footer-tagline">Modern HR management platform for growing businesses.</p>
    </div>
    {columns.map((column) => (
      <div class="footer-column">
        <h3 class="footer-column-title">{column.label}</h3>
        <ul class="footer-links">
          {column.links.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} HR Service. All rights reserved.</p>
  </div>
</footer>

<style>
  .doc-footer {
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 3rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }

  .doc-footer .meta {
    gap: 0.75rem 3rem;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .doc-footer .meta > :global(p:only-child) {
    margin-inline-start: auto;
  }

  .doc-footer .kudos {
    align-items: center;
    gap: 0.5em;
    margin: 1.5rem auto;
    font-size: var(--sl-text-xs);
    text-decoration: none;
    color: var(--sl-color-gray-3);
  }

  .doc-footer .kudos:hover {
    color: var(--sl-color-accent);
  }

  .site-footer {
    margin-top: 4rem;
    background: #111827;
    color: #d1d5db;
    padding: 3rem 0 0;
  }

  .site-footer-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .site-footer-inner { padding: 0 1.5rem 2rem; }
  }

  @media (min-width: 1024px) {
    .site-footer-inner {
      padding: 0 2rem 2rem;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .footer-brand {
    grid-column: 1 / -1;
  }

  @media (min-width: 1024px) {
    .footer-brand { grid-column: span 1; }
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-icon {
    width: 2.5rem;
    height: 2.5rem;
    background: #1B4DDB;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-logo-svg {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
  }

  .footer-logo-text {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
    max-width: 20rem;
  }

  .footer-column-title {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    margin: 0 0 1rem 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: #d1d5db;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: white;
  }

  .footer-bottom {
    border-top: 1px solid #1f2937;
    padding: 2rem 1rem;
    text-align: center;
    font-size: 0.875rem;
  }

  @media (min-width: 640px) {
    .footer-bottom { padding: 2rem 1.5rem; }
  }

  @media (min-width: 1024px) {
    .footer-bottom { padding: 2rem; }
  }
</style>
