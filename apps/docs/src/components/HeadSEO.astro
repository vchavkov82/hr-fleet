---
/**
 * HeadSEO — injects BreadcrumbList JSON-LD into every docs page.
 * Override Starlight's Head component to add structured data.
 */
import Default from '@astrojs/starlight/components/Head.astro';

const { entry, locale } = Astro.props;
const siteUrl = 'https://docs.jobshr.com';

// Build breadcrumb items from the page slug
const slug = entry?.slug ?? '';
const segments = slug.split('/').filter(Boolean);

// Build breadcrumb list
const breadcrumbItems = [
  { name: 'Docs', url: siteUrl + '/' },
];

let currentPath = '';
for (const segment of segments) {
  currentPath += '/' + segment;
  const name = segment
    .split('-')
    .map((w: string) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
  breadcrumbItems.push({
    name,
    url: siteUrl + currentPath + '/',
  });
}

// Override last item name with actual page title if available
if (entry?.data?.title && breadcrumbItems.length > 1) {
  breadcrumbItems[breadcrumbItems.length - 1].name = entry.data.title;
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<Default {...Astro.props}><slot /></Default>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
