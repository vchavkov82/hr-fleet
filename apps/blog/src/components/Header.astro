---
import { SITE } from "@/config";

const { pathname } = Astro.url;
const currentPath = pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  return currentPath === path || currentPath.startsWith(path + "/");
};

const baseUrl = "https://hr.svc.chavkov.com";

const NAV_LINKS = [
  { label: "Home", href: `${baseUrl}/` },
  { label: "Features", href: `${baseUrl}/features` },
  { label: "Pricing", href: `${baseUrl}/pricing` },
  { label: "Blog", href: "/", isLocal: true },
  { label: "Docs", href: "https://docs.jobshr.com/" },
  { label: "About", href: `${baseUrl}/about` },
  { label: "Help Center", href: `${baseUrl}/help-center` },
  { label: "Contact", href: `${baseUrl}/contact` },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-white px-4 py-2 text-[#1B4DDB] transition-all focus:top-4 rounded-lg shadow-lg"
>
  Skip to content
</a>

<nav class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={`${baseUrl}/`} class="flex items-center gap-3">
        <div class="w-10 h-10 bg-[#1B4DDB] rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
          </svg>
        </div>
        <span class="text-xl font-heading font-semibold text-gray-900">HR Service</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {NAV_LINKS.map((link) => {
          const active = link.isLocal ? isActive("/") || isActive("/posts") || isActive("/blog") : false;
          return (
            <a
              href={link.href}
              class:list={[
                "text-sm transition-colors",
                active ? "text-[#1B4DDB] font-medium" : "text-gray-600 hover:text-gray-900"
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </div>

      <div class="hidden md:flex items-center gap-4">
        <a href={`${baseUrl}/auth/login`} class="text-sm text-gray-600 hover:text-gray-900 transition-colors">
          Sign In
        </a>
        <a
          href={`${baseUrl}/auth/sign-up`}
          class="px-4 py-2 bg-[#1B4DDB] text-white rounded-lg hover:bg-[#133AAB] transition-colors text-sm font-medium"
        >
          Get Started
        </a>
      </div>

      <button
        id="menu-btn"
        class="md:hidden p-2 text-gray-600 hover:text-gray-900"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <div class="px-4 py-4 space-y-3">
      {NAV_LINKS.map((link) => {
        const active = link.isLocal ? isActive("/") || isActive("/posts") || isActive("/blog") : false;
        return (
          <a
            href={link.href}
            class:list={[
              "block px-4 py-2 rounded-lg text-sm",
              active ? "bg-[#EEF2FF] text-[#1B4DDB]" : "text-gray-600 hover:bg-gray-50"
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <div class="pt-3 border-t border-gray-200 space-y-2">
        <a
          href={`${baseUrl}/auth/login`}
          class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 rounded-lg"
        >
          Sign In
        </a>
        <a
          href={`${baseUrl}/auth/sign-up`}
          class="block px-4 py-2 bg-[#1B4DDB] text-white rounded-lg hover:bg-[#133AAB] text-center text-sm"
        >
          Get Started
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  function setupMobileMenu() {
    const menuBtn = document.querySelector("#menu-btn");
    const mobileMenu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      mobileMenu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
