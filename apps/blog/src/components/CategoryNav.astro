---
import { CATEGORIES } from "@/utils/getPostsByCategory";

interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props;
---

<nav aria-label="Blog categories" class="w-full overflow-x-auto">
  <ul class="flex gap-2 py-2 min-w-max">
    <li>
      <a
        href="/posts/"
        class:list={[
          "inline-block rounded-full px-4 py-1.5 text-sm font-medium transition-colors",
          !activeCategory
            ? "bg-blue-600 text-white"
            : "bg-gray-100 text-gray-700 hover:bg-gray-200",
        ]}
      >
        All
      </a>
    </li>
    {
      CATEGORIES.map(cat => (
        <li>
          <a
            href={`/categories/${cat.slug}/`}
            class:list={[
              "inline-block whitespace-nowrap rounded-full px-4 py-1.5 text-sm font-medium transition-colors",
              activeCategory === cat.slug
                ? "bg-blue-600 text-white"
                : "bg-gray-100 text-gray-700 hover:bg-gray-200",
            ]}
          >
            {cat.name}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
