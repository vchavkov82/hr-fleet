---
// Stats section component
---

<section class="py-20 sm:py-28 bg-navy-deep text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl font-bold mb-6">
        Trusted by companies worldwide
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Managing global teams at scale
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { value: "10k+", label: "Active Users" },
        { value: "150+", label: "Countries" },
        { value: "$500M+", label: "Payroll Managed" },
        { value: "99.9%", label: "Uptime" }
      ].map(stat => (
        <div class="text-center">
          <div class="text-5xl font-bold text-primary mb-2">{stat.value}</div>
          <div class="text-lg text-gray-300">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
