---
type Props = {
  name: string;
  bio?: string;
  avatar?: string;
  social?: string;
};

const { name, bio, avatar, social } = Astro.props;
const initials = name
  .split(" ")
  .map(w => w[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);
---

<div class="mt-12 pt-8 border-t border-gray-200">
  <div class="flex items-start gap-4">
    {avatar ? (
      <img
        src={avatar}
        alt={name}
        class="w-16 h-16 rounded-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white font-semibold text-lg flex-shrink-0">
        {initials}
      </div>
    )}
    <div>
      <div class="flex items-center gap-2">
        {social ? (
          <a href={social} class="font-semibold text-gray-900 hover:text-blue-600 transition-colors">
            {name}
          </a>
        ) : (
          <span class="font-semibold text-gray-900">{name}</span>
        )}
      </div>
      {bio && <p class="text-sm text-gray-600 mt-1">{bio}</p>}
    </div>
  </div>
</div>
