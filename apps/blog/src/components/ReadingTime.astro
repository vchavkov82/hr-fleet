---
type Props = {
  readingTime: string;
  class?: string;
};

const { readingTime, class: className = "" } = Astro.props;
---

<span class={`inline-flex items-center gap-1 text-sm text-gray-500 ${className}`}>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>
  {readingTime}
</span>
