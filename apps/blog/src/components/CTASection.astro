---
// CTA section component
---

<section class="py-20 sm:py-28 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/18 via-[var(--surface)] to-accent/12" />
  <div class="absolute inset-0 opacity-60 mix-blend-screen" style="background: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.65), transparent 35%), radial-gradient(circle at 80% 40%, rgba(27,77,219,0.25), transparent 40%);"></div>
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center rounded-3xl border border-border bg-[var(--surface)]/85 backdrop-blur shadow-[0_24px_80px_-40px_rgba(0,0,0,0.5)] py-14 sm:py-16">
    <h2 class="text-4xl sm:text-5xl font-bold text-navy dark:text-gray-50 mb-4">
      Ready to transform your HR operations?
    </h2>
    <p class="text-lg sm:text-xl text-gray-700 dark:text-gray-200 mb-10 max-w-3xl mx-auto">
      Join thousands of companies using HR to manage their global workforce efficiently.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="https://hr.svc.chavkov.com/bg/auth/sign-up" class="inline-flex items-center justify-center px-8 py-4 rounded-xl text-white font-semibold shadow-[0_18px_44px_-18px_rgba(27,77,219,0.95)] hover:shadow-[0_20px_52px_-16px_rgba(27,77,219,1)] transition-all bg-brand-gradient text-lg">
        Start Free Trial
      </a>
      <a href="https://hr.svc.chavkov.com/bg/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-xl text-foreground font-semibold border border-border bg-[var(--surface-strong)]/80 hover:border-primary/50 hover:text-primary transition-all text-lg">
        Schedule Demo
      </a>
    </div>
  </div>
</section>
