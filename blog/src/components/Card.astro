---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
  display?: "minimal" | "card" | "featured";
} & CollectionEntry<"blog">;

const {
  variant: Heading = "h2",
  display = "minimal",
  id,
  data,
  filePath,
} = Astro.props;

const { title, description, tags, ...props } = data;

const href = getPath(id, filePath);
const firstTag = tags?.[0];

const isMinimal = display === "minimal";
const isFeatured = display === "featured";
---

<li class:list={[isMinimal ? "my-6" : ""]}>
  {
    isMinimal ? (
      <>
        <a
          href={href}
          class="inline-block text-lg font-semibold text-blue-600 decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
        >
          <Heading
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          >
            {title}
          </Heading>
        </a>
        <Datetime {...props} class="text-gray-500" />
        <p class="mt-2 text-sm leading-relaxed text-gray-600">{description}</p>
      </>
    ) : (
      <article class:list={[
        "group h-full overflow-hidden rounded-xl border border-gray-200 bg-white hover:shadow-lg hover:border-blue-300 transition-all",
        isFeatured ? "md:grid md:grid-cols-2" : "",
      ]}>
        <a href={href} class="block h-full">
          <div class:list={[
            "aspect-video w-full bg-gradient-to-br from-blue-50 via-white to-purple-50",
            isFeatured ? "md:aspect-auto md:h-full md:min-h-[18rem]" : "",
          ]} />
          <div class:list={[
            "flex h-full flex-col gap-3 p-6",
            isFeatured ? "md:p-8" : "",
          ]}>
            <div class="flex items-center gap-3">
              {firstTag && (
                <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs font-medium">
                  {firstTag}
                </span>
              )}
              <Datetime {...props} class="text-gray-500" />
            </div>

            <Heading
              class:list={[
                "text-balance font-bold text-gray-900 group-hover:text-blue-600 transition-colors",
                isFeatured ? "text-2xl sm:text-3xl" : "text-lg",
              ]}
              style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            >
              {title}
            </Heading>

            <p class:list={[
              "text-sm leading-relaxed text-gray-600 line-clamp-2",
              isFeatured ? "text-base" : "",
            ]}>
              {description}
            </p>

            <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white text-xs font-semibold">
                  HR
                </div>
                <span class="text-xs font-medium text-gray-900">HR Team</span>
              </div>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      </article>
    )
  }
</li>
