---
// CloudflareImage.astro — wrapper for CF Image Resizing in Astro SSG blogs.
// Generates /cdn-cgi/image/ URLs for on-the-fly WebP/AVIF conversion at the CF edge.
// Use instead of Astro's <Image> for content images in blog posts/article covers.
//
// Why NOT Astro's built-in <Image>: These blogs deploy as static files behind Caddy,
// not on CF Pages/Workers. passthroughImageService() is used so Astro doesn't try to
// optimize images at build time with Sharp. CF handles optimization at the edge.

interface Props {
  src: string;
  alt: string;
  width: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  quality?: number;
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  loading = 'lazy',
  quality = 80,
} = Astro.props;

// Build CF transform URL — relative path works when the site is behind CF proxy
const cfUrl = [
  `/cdn-cgi/image/width=${width}`,
  height ? `height=${height}` : null,
  `quality=${quality}`,
  'format=auto',
].filter(Boolean).join(',') + `/${src}`;

// Tiny blurred placeholder as CSS background to prevent CLS
const blurUrl = `/cdn-cgi/image/width=10,quality=10,blur=20,format=webp/${src}`;
---

<img
  src={cfUrl}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  decoding="async"
  class={className}
  style={`background-image: url('${blurUrl}'); background-size: cover; background-position: center;`}
/>
