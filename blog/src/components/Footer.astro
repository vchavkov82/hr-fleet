---
const currentYear = new Date().getFullYear();

const columns = [
  {
    label: "ПРОДУКТ",
    links: [
      { label: "ATS / Подбор", href: "https://hr.svc.chavkov.com/bg/features#ats" },
      { label: "Управление на служители", href: "https://hr.svc.chavkov.com/bg/features#employees" },
      { label: "Отпуски", href: "https://hr.svc.chavkov.com/bg/features#leave" },
      { label: "Заплати", href: "https://hr.svc.chavkov.com/bg/features#payroll" },
      { label: "Оценки на представянето", href: "https://hr.svc.chavkov.com/bg/features#performance" },
    ],
  },
  {
    label: "РЕСУРСИ",
    links: [
      { label: "Блог", href: "/bg" },
      { label: "HR Инструменти", href: "https://hr.svc.chavkov.com/bg/hr-tools" },
      { label: "Помощен център", href: "https://hr.svc.chavkov.com/bg/help-center" },
    ],
  },
  {
    label: "КОМПАНИЯ",
    links: [
      { label: "За нас", href: "https://hr.svc.chavkov.com/bg/about" },
      { label: "Кариери", href: "https://hr.svc.chavkov.com/bg/careers" },
      { label: "Партньори", href: "https://hr.svc.chavkov.com/bg/partners" },
      { label: "Контакти", href: "https://hr.svc.chavkov.com/bg/contact" },
    ],
  },
  {
    label: "ПРАВНА ИНФОРМАЦИЯ",
    links: [
      { label: "Условия за ползване", href: "https://hr.svc.chavkov.com/bg/terms" },
      { label: "Политика за поверителност", href: "https://hr.svc.chavkov.com/bg/privacy" },
      { label: "Политика за бисквитки", href: "https://hr.svc.chavkov.com/bg/cookies" },
      { label: "GDPR", href: "https://hr.svc.chavkov.com/bg/gdpr" },
    ],
  },
];

const trustBadges = [
  { label: "SOC 2", icon: "🛡️" },
  { label: "GDPR", icon: "🔒" },
  { label: "ISO 27001", icon: "✅" },
];
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 lg:gap-10">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <a href="https://hr.svc.chavkov.com/bg" class="flex items-center gap-2.5 font-bold text-xl">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold text-white" style="background: linear-gradient(135deg, #1B4DDB 0%, #3B6EF0 100%);">
            HR
          </span>
          HR
        </a>
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          Цялостната HR платформа за български бизнеси. Наемайте, управлявайте и развивайте екипа си от едно място.
        </p>
        <div class="mt-6 flex gap-3">
          <a
            href="#"
            class="w-9 h-9 rounded-lg bg-navy-light flex items-center justify-center text-gray-400 hover:text-white hover:bg-primary transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href="#"
            class="w-9 h-9 rounded-lg bg-navy-light flex items-center justify-center text-gray-400 hover:text-white hover:bg-primary transition-colors"
            aria-label="Twitter/X"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {columns.map((column) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">
            {column.label}
          </h3>
          <ul class="space-y-3">
            {column.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-300 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Trust badges and bottom section -->
    <div class="mt-12 pt-8 border-t border-navy-light">
      <div class="flex flex-wrap items-center justify-center gap-6 mb-8">
        {trustBadges.map((badge) => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-navy-light text-sm text-gray-300">
            <span>{badge.icon}</span>
            <span class="font-medium">{badge.label} Съответстващ</span>
          </div>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-gray-500">
          &copy; {currentYear} HR. Всички права запазени.
        </p>
        <div class="flex items-center gap-4 text-xs text-gray-500">
          <a href="https://hr.svc.chavkov.com/bg/terms" class="hover:text-gray-300 transition-colors">
            Условия
          </a>
          <a href="https://hr.svc.chavkov.com/bg/privacy" class="hover:text-gray-300 transition-colors">
            Поверителност
          </a>
          <a href="https://hr.svc.chavkov.com/bg/cookies" class="hover:text-gray-300 transition-colors">
            Бисквитки
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .bg-navy {
    background-color: #0F172A;
  }
  .bg-navy-light {
    background-color: #1E293B;
  }
  .border-navy-light {
    border-color: #1E293B;
  }
  .hover\:bg-primary:hover {
    background-color: #1B4DDB;
  }
</style>
