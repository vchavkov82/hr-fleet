# HR Product — Caddy Reverse Proxy
# All app services sit behind Caddy; users only ever see port 80/443.
#
# Environment variables (set in .env or container env):
#   HR_DOMAIN       HR marketing site      e.g. hr.assistance.bg
#   HR_BLOG_DOMAIN  HR blog subdomain      e.g. blog.hr.assistance.bg
#   HR_DOCS_DOMAIN  HR docs subdomain      e.g. docs.hr.assistance.bg
#   HR_ADMIN_DOMAIN HR admin panel         e.g. admin.hr.assistance.bg
#   HR_ODOO_DOMAIN  Odoo ERP backend       e.g. odoo.hr.assistance.bg
#   ACME_EMAIL      Let's Encrypt contact  e.g. admin@assistance.bg
#
# Default domains: hr.assistance.bg, blog.hr.assistance.bg, docs.hr.assistance.bg,
#   admin.hr.assistance.bg, odoo.hr.assistance.bg

{
	email {$ACME_EMAIL:admin@assistance.bg}
}

# ── Shared snippet for common security headers ─────────────────────────────
(common_headers) {
	header {
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		Referrer-Policy            "strict-origin-when-cross-origin"
		X-XSS-Protection          "0"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		Content-Security-Policy   "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https:; frame-ancestors 'none'"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

# ── HR marketing site (Next.js) ─────────────────────────────────────────────
{$HR_DOMAIN:hr.assistance.bg} {
	encode gzip zstd
	import common_headers

	# Immutable cache for Next.js hashed static assets
	header /_next/static/* Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	# Next.js image optimizer
	header /_next/image* Cache-Control "public, max-age=86400, s-maxage=86400, stale-while-revalidate=604800"

	# Web fonts and static images
	header /*.woff2 Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"
	header /*.woff  Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	# Go backend API
	handle /api/v1/* {
		header {
			Access-Control-Allow-Origin "{$HR_CORS_ORIGIN:*}"
			Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization"
			Access-Control-Max-Age "3600"
		}
		reverse_proxy hr-api:8080
	}

	handle {
		reverse_proxy hr:3010
	}
}

# ── HR blog (Astro) ─────────────────────────────────────────────────────────
{$HR_BLOG_DOMAIN:blog.hr.assistance.bg} {
	encode gzip zstd
	import common_headers

	# Astro build — content-hashed chunks are immutable
	header /_astro/* Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	# Pagefind search index
	header /pagefind/* Cache-Control "public, max-age=3600, s-maxage=86400"

	# Web fonts
	header /*.woff2 Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"
	header /*.woff  Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	# Non-hashed JS/CSS
	header /*.js  Cache-Control "public, max-age=3600, s-maxage=86400"
	header /*.css Cache-Control "public, max-age=3600, s-maxage=86400"

	handle {
		reverse_proxy hr-blog:3013
	}
}

# ── Admin panel (Vite SPA) ──────────────────────────────────────────────────
{$HR_ADMIN_DOMAIN:admin.hr.assistance.bg} {
	encode gzip zstd
	import common_headers

	# Vite build — content-hashed chunks are immutable
	header /assets/* Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	handle {
		reverse_proxy hr-admin:5014
	}
}

# ── HR docs (Astro Starlight) ───────────────────────────────────────────────
{$HR_DOCS_DOMAIN:docs.hr.assistance.bg} {
	encode gzip zstd
	import common_headers

	# Astro build — content-hashed chunks are immutable
	header /_astro/* Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	# Web fonts
	header /*.woff2 Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"
	header /*.woff  Cache-Control "public, max-age=31536000, s-maxage=31536000, immutable"

	# Non-hashed JS/CSS
	header /*.js  Cache-Control "public, max-age=3600, s-maxage=86400"
	header /*.css Cache-Control "public, max-age=3600, s-maxage=86400"

	handle {
		reverse_proxy hr-docs:3011
	}
}

# ── Odoo ERP Backend ─────────────────────────────────────────────────────────
{$HR_ODOO_DOMAIN:odoo.hr.assistance.bg} {
	encode gzip zstd

	# Odoo-specific headers (relaxed CSP for Odoo's dynamic content)
	header {
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		Referrer-Policy           "strict-origin-when-cross-origin"
		X-XSS-Protection          "0"
		-Server
	}

	# Odoo static assets
	header /web/static/* Cache-Control "public, max-age=31536000, immutable"
	header /web/assets/* Cache-Control "public, max-age=31536000, immutable"

	# Websocket support for Odoo longpolling
	handle /websocket {
		reverse_proxy hr-odoo:8072
	}

	handle /longpolling/* {
		reverse_proxy hr-odoo:8072
	}

	handle {
		reverse_proxy hr-odoo:8069 {
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}
