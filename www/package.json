{
  "name": "@hr/www",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'pids=$(ss -ltnp \"sport = :3010\" 2>/dev/null | sed -n \"s/.*pid=\\([0-9]\\+\\).*/\\1/p\" | sort -u); if [ -n \"$pids\" ]; then kill -9 $pids >/dev/null 2>&1; fi; NEXT_DISABLE_FAST_REFRESH=1 next dev -H 0.0.0.0 -p 3010'",
    "dev:webpack": "NEXT_DISABLE_FAST_REFRESH=1 next dev -H 0.0.0.0 -p 3010",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3010",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --project=firefox",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run test",
    "format": "prettier --write .",
    "clean": "rm -rf .next node_modules/.cache",
    "clean:start": "pnpm run clean && pnpm run start",
    "stop": "sh -c 'pids=$(ss -ltnp \"sport = :3010\" 2>/dev/null | sed -n \"s/.*pid=\\([0-9]\\+\\).*/\\1/p\" | sort -u); if [ -n \"$pids\" ]; then kill -9 $pids >/dev/null 2>&1 || true; fi'"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@an-sdk/agent": "^0.0.5",
    "@an-sdk/nextjs": "^0.0.8",
    "@an-sdk/node": "^0.0.2",
    "@an-sdk/react": "^0.1.2",
    "@headlessui/react": "^2.2.0",
    "@hookform/resolvers": "^3.9.1",
    "ai": "^6.0.116",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "gray-matter": "^4.0.3",
    "next": "^15.2.0",
    "next-intl": "^4.8.3",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "remark-gfm": "^4.0.1",
    "swiper": "^12.1.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "5.5.4",
    "vitest": "^2.1.4"
  }
}
